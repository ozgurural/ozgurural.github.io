{
  "name": "ozgurural-portfolio",
  "version": "1.0.0",
  "description": "Personal academic and engineering portfolio for Dr. Ozgur Ural",
  "repository": {
    "type": "git",
    "url": "https://github.com/ozgurural/ozgurural.github.io"
  },
  "private": true,
  "keywords": [
    "jekyll",
    "portfolio"
  ],
  "contributors": [
    "Ozgur Ural"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ozgurural/ozgurural.github.io/issues"
  },
  "homepage": "https://github.com/ozgurural/ozgurural.github.io",
  "engines": {
    "node": ">= 0.10.0"
  },
  "dependencies": {
    "fitvids": "^2.1.1",
    "jquery": "^3.7.1",
    "jquery-smooth-scroll": "^2.2.0",
    "puppeteer": "^25.3.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "onchange": "^7.1.0",
    "uglify-js": "^3.17.4"
  },
  "scripts": {
    "uglify": "uglifyjs node_modules/jquery/dist/jquery.min.js node_modules/fitvids/dist/fitvids.min.js node_modules/jquery-smooth-scroll/jquery.smooth-scroll.min.js assets/js/plugins/jquery.greedy-navigation.js assets/js/_main.js -c -m -o assets/js/main.min.js",
    "watch:js": "onchange \"assets/js/**/*.js\" -e \"assets/js/main.min.js\" -- npm run build:js",
    "build:js": "npm run uglify",
    "build:lab-og": "node scripts/build-lab-og.js",
    "build:narration": "node scripts/extract-narration.js && python scripts/generate-narration.py"
  }
}
